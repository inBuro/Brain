.DS_Store
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/plugins/obsidian-git/.git_credentials_input
.obsidian/cache
.obsidian/plugins/*/data.json
.trash/
*.tmp
.gstack/

# Claude Code worktrees — independent git repos under .claude/worktrees/, never embed as submodules
**/.claude/worktrees/

# Secrets — never commit
.env
.env.*
!.env.example
*.pem
*.key
**/credentials.json
**/secrets.json
.dev.vars

# Brain sync logs — generated by scripts/sync-from-main.sh via launchd
scripts/sync.log
scripts/sync.err.log
# Trigger-listener logs + cloud-side secret config
scripts/sync-trigger.log
scripts/sync-trigger.err.log
scripts/.trigger.env

# Large rebuildable build artifacts + dated bundle backups — keep on disk, NEVER commit.
# These exceeded GitHub's 100MB/file limit and silently broke autobackup for ~3 weeks;
# history was cleaned with git-filter-repo on 2026-06-17. Bundles rebuild from dist/ source.
Fadercraft/dist/*.zip
Fadercraft/raw/archive/*.zip
Fadercraft/raw/Demo-set Project/Samples/Processed/Crop/Melody 1 28 *.aif
