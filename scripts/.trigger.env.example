# Copy to scripts/.trigger.env (gitignored) once you've finished the Mac-side
# Cloudflare Tunnel setup. Used by scripts/trigger-sync.sh on the remote
# Claude / SSH side to kick local brain-sync on demand.
#
# Same BRAIN_SYNC_SECRET must be set in:
#   - This file (cloud side, what trigger-sync.sh sends)
#   - The com.inburo.brain-sync-trigger LaunchAgent on the Mac
#     (EnvironmentVariables → BRAIN_SYNC_SECRET in
#      ~/Library/LaunchAgents/com.inburo.brain-sync-trigger.plist)
#
# Generate the secret once:
#   openssl rand -hex 32

BRAIN_SYNC_URL="https://brain-sync.YOUR-DOMAIN.com"
BRAIN_SYNC_SECRET="REPLACE_ME_WITH_openssl_rand_hex_32"
